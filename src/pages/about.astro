---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SectionHeading from "~/components/SectionHeading.astro";
import CTABanner from "~/components/CTABanner.astro";
import { FIRM } from "~/data/firm";
---

<BaseLayout
  title="About the Firm"
  description="About FBW LLP — our founding principles, how we work, and what we stand for."
>
  <section class="border-b border-graphite-200 bg-paper-50">
    <div class="container-editorial pt-20 pb-20 md:pt-28 md:pb-24">
      <SectionHeading
        eyebrow="About the Firm"
        title="Three partners. One standard. A firm built on listening."
        as="h1"
      />
    </div>
  </section>

  <section class="bg-paper-50">
    <div class="container-editorial grid grid-cols-1 gap-12 py-16 md:py-20 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-4">
        <h2 class="eyebrow">Our story</h2>
      </div>
      <div class="space-y-6 text-lg leading-relaxed text-graphite-700 lg:col-span-8">
        <p>
          {FIRM.longDescription}
        </p>
        <p>
          We are a deliberate, focused firm. We do not chase volume; we are
          chosen, quite often, by clients who have been through a larger firm
          and who want something different the second time. That second‑time
          client is the standard against which we measure our own work.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-paper-100">
    <div class="container-editorial grid grid-cols-1 gap-12 py-20 md:py-28 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-4">
        <h2 class="eyebrow">Principles</h2>
        <p class="mt-4 font-display text-3xl leading-tight text-ink-900 md:text-4xl">
          Four commitments we make to every client.
        </p>
      </div>

      <div class="lg:col-span-8">
        <dl class="space-y-10">
          <div class="grid grid-cols-[auto,1fr] gap-x-8 border-t border-graphite-300 pt-6">
            <dt class="chapter-marker">I.</dt>
            <div>
              <h3 class="font-display text-2xl text-ink-900">A partner on every file.</h3>
              <p class="mt-3 text-graphite-700">
                The partner identified in your engagement letter is the
                partner doing the work — and the partner you should expect to
                hear from when there is news.
              </p>
            </div>
          </div>

          <div class="grid grid-cols-[auto,1fr] gap-x-8 border-t border-graphite-300 pt-6">
            <dt class="chapter-marker">II.</dt>
            <div>
              <h3 class="font-display text-2xl text-ink-900">Clarity in language and fees.</h3>
              <p class="mt-3 text-graphite-700">
                We commit to plain‑language explanations, a clear fee
                structure at the start of every engagement, and no surprise
                invoices at the end.
              </p>
            </div>
          </div>

          <div class="grid grid-cols-[auto,1fr] gap-x-8 border-t border-graphite-300 pt-6">
            <dt class="chapter-marker">III.</dt>
            <div>
              <h3 class="font-display text-2xl text-ink-900">Honest scope.</h3>
              <p class="mt-3 text-graphite-700">
                If a matter sits outside our areas of practice, we will tell
                you — and, where we can, refer you to counsel we respect.
              </p>
            </div>
          </div>

          <div class="grid grid-cols-[auto,1fr] gap-x-8 border-t border-graphite-300 pt-6">
            <dt class="chapter-marker">IV.</dt>
            <div>
              <h3 class="font-display text-2xl text-ink-900">The long view.</h3>
              <p class="mt-3 text-graphite-700">
                We would rather be your firm for twenty years than your firm
                for one transaction. Many of our best client relationships
                have outlasted every other adviser in the file.
              </p>
            </div>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section id="careers" class="bg-paper-50">
    <div class="container-editorial grid grid-cols-1 gap-12 py-20 md:py-28 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-4">
        <h2 class="eyebrow">Careers</h2>
        <p class="mt-4 font-display text-3xl leading-tight text-ink-900 md:text-4xl">
          Join a firm where every file is worth doing well.
        </p>
      </div>
      <div class="space-y-6 text-lg leading-relaxed text-graphite-700 lg:col-span-8">
        <p>
          FBW LLP hires lawyers, articling students, and staff who share our
          conviction that careful, client‑first legal work is a craft —
          and that the profession, at its best, is a long apprenticeship in
          that craft.
        </p>
        <p>
          If you are interested in joining us, we would be glad to hear
          from you. Please send a résumé and a short note to
          <a href={`mailto:${FIRM.email}`} class="text-gold-600 underline">{FIRM.email}</a>
          with the subject line <em>Careers — [Your Name]</em>.
        </p>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
