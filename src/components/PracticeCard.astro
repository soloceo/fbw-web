---
export interface Props {
  slug: string;
  title: string;
  summary: string;
  index: number;
  href?: string;
}

import { withBase } from "~/lib/url";

const { slug, title, summary, index, href } = Astro.props;
const target = href ?? withBase(`/practice-areas/${slug}`);
const roman = ["I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X", "XI", "XII"][index] ?? String(index + 1);
---

<a
  href={target}
  class="group relative flex flex-col gap-5 border-t border-graphite-300/70 py-8 transition-colors hover:border-gold-500 md:py-10"
>
  <div class="flex items-start justify-between gap-6">
    <div class="flex-1">
      <span class="chapter-marker">{roman}.</span>
      <h3 class="mt-2 font-display text-2xl text-ink-900 transition-colors group-hover:text-gold-600 md:text-3xl lg:text-[2rem]">
        {title}
      </h3>
      <p class="mt-4 max-w-xl text-[15px] leading-relaxed text-graphite-700">
        {summary}
      </p>
    </div>
    <span
      aria-hidden="true"
      class="mt-4 font-display text-4xl text-graphite-300 transition-all duration-500 group-hover:translate-x-2 group-hover:text-gold-500 md:text-5xl"
      >→</span
    >
  </div>
</a>
