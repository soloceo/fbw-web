---
import { FIRM, SEO_DEFAULT, OFFICES } from "~/data/firm";
import { absoluteUrl, withBase } from "~/lib/url";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
}

const {
  title,
  description = SEO_DEFAULT.description,
  ogImage = SEO_DEFAULT.ogImage,
  canonical,
  schema,
  noindex = false,
} = Astro.props;

const fullTitle = title ? `${title} — ${FIRM.name}` : SEO_DEFAULT.title;

// canonical / og:url — derive from the actual origin + path so the URL is
// always accurate, whether we are on soloceo.github.io/fbw-web or a future
// fbwlaw.ca. `Astro.url.pathname` already includes the base.
const canonicalUrl =
  canonical || new URL(Astro.url.pathname, Astro.site).toString();

// og:image resolved as an absolute URL (external URLs pass through).
const ogImageUrl = ogImage.startsWith("http")
  ? ogImage
  : absoluteUrl(ogImage, Astro.site ?? new URL("http://localhost"));

// Use the actual deployed site origin + base as the firm's schema identity.
// When we swap DNS to fbwlaw.ca, this updates automatically.
const firmIdUrl = new URL(withBase("/"), Astro.site ?? new URL("http://localhost")).toString();
const firmId = `${firmIdUrl}#legalservice`;

// Phone in E.164 form per Google schema guidance.
const telE164 = FIRM.mainPhone.replace(/[^\d+]/g, "");

// Head office (Toronto) is the primary address; branch offices are
// enumerated as `location` entries. One `address` per LegalService is the
// schema.org norm.
const head = OFFICES.find((o) => o.role === "Head Office") ?? OFFICES[0];

const baseSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  "@id": firmId,
  name: FIRM.legalName,
  alternateName: FIRM.name,
  description: FIRM.shortDescription,
  url: firmIdUrl,
  email: FIRM.email,
  telephone: telE164,
  priceRange: "$$$",
  areaServed: [
    { "@type": "AdministrativeArea", name: "Ontario" },
    { "@type": "City", name: "Toronto" },
    { "@type": "City", name: "Markham" },
    { "@type": "City", name: "Oakville" },
  ],
  address: {
    "@type": "PostalAddress",
    streetAddress: `${head.address1}${head.address2 ? ", " + head.address2 : ""}`,
    addressLocality: head.city,
    addressRegion: head.province,
    postalCode: head.postal,
    addressCountry: head.country,
  },
  location: OFFICES.map((o) => ({
    "@type": "Place",
    name: `${FIRM.name} — ${o.name}`,
    address: {
      "@type": "PostalAddress",
      streetAddress: `${o.address1}${o.address2 ? ", " + o.address2 : ""}`,
      addressLocality: o.city,
      addressRegion: o.province,
      postalCode: o.postal,
      addressCountry: o.country,
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: o.lat,
      longitude: o.lng,
    },
  })),
};

const structuredData = schema
  ? Array.isArray(schema)
    ? [baseSchema, ...schema]
    : [baseSchema, schema]
  : baseSchema;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={FIRM.name} />
<meta property="og:locale" content={SEO_DEFAULT.locale} />
<meta property="og:image" content={ogImageUrl} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />
