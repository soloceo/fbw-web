---
import { FIRM, NAV_PRIMARY } from "~/data/firm";

export interface Props {
  theme?: "paper" | "ink";
}

const { theme = "paper" } = Astro.props;
const isInk = theme === "ink";
const logoSrc = isInk
  ? `${import.meta.env.BASE_URL}brand/logo-white.svg`
  : `${import.meta.env.BASE_URL}brand/logo-black.svg`;

const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<header
  class:list={[
    "site-header sticky top-0 z-50 border-b transition-colors duration-300",
    isInk
      ? "border-ink-800 bg-ink-950/90 text-paper-50 backdrop-blur"
      : "border-graphite-200/60 bg-paper-50/85 text-ink-900 backdrop-blur",
  ]}
>
  <div class="container-editorial flex items-center justify-between py-5 lg:py-7">
    <a href={import.meta.env.BASE_URL} class="inline-flex items-center" aria-label={`${FIRM.name} — Home`}>
      <img src={logoSrc} alt={FIRM.name} class="h-8 w-auto md:h-10" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:block" aria-label="Primary">
      <ul class="flex items-center gap-9">
        {
          NAV_PRIMARY.map((item) => {
            const normalized = item.href.replace(/\/$/, "");
            const active =
              currentPath === normalized ||
              (normalized !== "" && currentPath.startsWith(normalized + "/"));
            return (
              <li>
                <a
                  href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}${item.href}`}
                  class:list={[
                    "relative text-[13px] uppercase tracking-[0.18em] transition-colors",
                    active
                      ? isInk
                        ? "text-gold-400"
                        : "text-gold-600"
                      : isInk
                        ? "text-paper-200 hover:text-gold-400"
                        : "text-graphite-700 hover:text-gold-600",
                  ]}
                  aria-current={active ? "page" : undefined}
                >
                  {item.label}
                  {active && (
                    <span class="absolute -bottom-1 left-0 h-px w-full bg-current opacity-80" />
                  )}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <a
      href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/contact`}
      class:list={[
        "hidden items-center gap-2 border px-5 py-2.5 text-[12px] uppercase tracking-[0.2em] transition-all lg:inline-flex",
        isInk
          ? "border-gold-500 text-gold-400 hover:bg-gold-500 hover:text-ink-950"
          : "border-ink-900 text-ink-900 hover:bg-ink-900 hover:text-paper-50",
      ]}
    >
      Consult
      <span aria-hidden="true">→</span>
    </a>

    <!-- Mobile menu toggle -->
    <button
      type="button"
      class="lg:hidden inline-flex h-10 w-10 items-center justify-center"
      aria-expanded="false"
      aria-controls="mobile-nav"
      data-nav-toggle
    >
      <span class="sr-only">Toggle menu</span>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav drawer -->
  <div
    id="mobile-nav"
    class="lg:hidden hidden border-t border-graphite-200/60 bg-paper-50"
    data-nav-panel
  >
    <nav class="container-editorial py-6" aria-label="Primary mobile">
      <ul class="flex flex-col gap-1">
        {
          NAV_PRIMARY.map((item) => (
            <li>
              <a
                href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}${item.href}`}
                class="block border-b border-graphite-200 py-3 font-display text-2xl text-ink-900 transition-colors hover:text-gold-600"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/contact`}
        class="mt-6 inline-flex w-full items-center justify-center gap-2 border border-ink-900 px-5 py-3 text-[12px] uppercase tracking-[0.2em] text-ink-900"
      >
        Request Consultation
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const panel = document.querySelector<HTMLDivElement>("[data-nav-panel]");
  toggle?.addEventListener("click", () => {
    const open = panel?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>
