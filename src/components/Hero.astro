---
import { FIRM } from "~/data/firm";
import { withBase } from "~/lib/url";
---

<section class="relative overflow-hidden bg-ink-950 text-paper-50">
  <!-- ============ Top institutional bar ============ -->
  <!-- A narrow, tracked strip that sits above the hero composition.
       Establishes jurisdiction and public registry status before
       anything marketing-oriented is said. -->
  <div class="relative z-10 border-b border-ink-800/80">
    <div class="container-editorial flex flex-wrap items-center justify-between gap-y-2 py-3.5 text-[10.5px] uppercase tracking-[0.28em] text-paper-200/75">
      <span class="smallcaps" style="letter-spacing: 0.3em;">
        Freedman · Benipal · Wu&nbsp;LLP
      </span>
      <span class="hidden md:inline">
        Ontario · Canada · Established {FIRM.yearFounded}
      </span>
      <a href={`tel:${FIRM.mainPhone.replace(/\s/g, "")}`} class="nums text-paper-200/70 hover:text-gold-400">
        {FIRM.mainPhone}
      </a>
    </div>
  </div>

  <!-- Colonnade pattern overlay — thin vertical rules like columns -->
  <div
    class="pointer-events-none absolute inset-0 colonnade-bg text-paper-50 opacity-40"
    aria-hidden="true"
  ></div>

  <!-- Soft radial vignette centred behind the title block -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse at 30% 45%, color-mix(in srgb, var(--color-gold-600) 12%, transparent) 0%, transparent 55%);"
    aria-hidden="true"
  ></div>

  <!-- ============ Hero composition ============ -->
  <div class="container-editorial relative grid min-h-[88vh] grid-cols-1 items-end py-24 md:min-h-[92vh] md:py-28 lg:grid-cols-12 lg:gap-12 lg:py-36">
    <div class="relative lg:col-span-9">
      <!-- Tracked introduction -->
      <span class="eyebrow" style="color: var(--color-gold-400);">
        Counsel for the Greater Toronto Area
      </span>

      <!-- Headline — direct, not lyrical. No italics. Serif weight 600. -->
      <h1 class="mt-10 font-display font-semibold leading-[0.98] tracking-[-0.018em] text-paper-50">
        <span class="block text-[clamp(2.5rem,7.2vw,5.75rem)]">
          Counsel for the decisions that
        </span>
        <span class="block text-[clamp(2.5rem,7.2vw,5.75rem)]">
          define a business,
        </span>
        <span class="block text-[clamp(2.5rem,7.2vw,5.75rem)] text-gold-400">
          a family, or a life.
        </span>
      </h1>

      <!-- Supporting paragraph — factual, not emotional -->
      <p class="mt-12 max-w-2xl text-[17px] leading-[1.75] text-paper-200/85 md:text-[18px]">
        FBW LLP is a Toronto, Markham, and Oakville law firm founded by three
        partners with complementary practices in real estate, corporate law,
        commercial litigation, wills&nbsp;&amp;&nbsp;estates, and immigration.
        Every engagement is partner‑led, fee‑disclosed at the outset, and
        answerable, from opening to close, by the partner whose name appears
        on your engagement letter.
      </p>

      <!-- Primary actions — no soft language -->
      <div class="mt-14 flex flex-col gap-5 sm:flex-row sm:items-center">
        <a
          href={withBase("/practice-areas")}
          class="group inline-flex items-center justify-center gap-3 border border-gold-500 bg-gold-500 px-8 py-4 text-[11px] uppercase tracking-[0.24em] text-ink-950 transition-colors hover:bg-gold-400 hover:border-gold-400"
        >
          Our Practice
          <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
        </a>
        <a
          href={withBase("/people")}
          class="group inline-flex items-center gap-3 px-2 text-[11px] uppercase tracking-[0.24em] text-paper-200/80 hover:text-gold-400"
        >
          <span>Meet the Partners</span>
          <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <!-- Right column: institutional facts list — the "title page" of the firm -->
    <div class="relative hidden lg:col-span-3 lg:flex lg:flex-col lg:justify-end lg:gap-7 lg:border-l lg:border-ink-800 lg:pl-9">
      <div>
        <p class="smallcaps text-[10.5px] text-gold-400">Offices</p>
        <ul class="mt-2 space-y-0.5 text-paper-200/85">
          <li>Toronto <span class="text-paper-200/45">&mdash; Head Office</span></li>
          <li>Markham</li>
          <li>Oakville</li>
        </ul>
      </div>
      <div>
        <p class="smallcaps text-[10.5px] text-gold-400">Jurisdiction</p>
        <p class="mt-2 text-paper-200/85">Ontario, Canada</p>
      </div>
      <div>
        <p class="smallcaps text-[10.5px] text-gold-400">Member</p>
        <p class="mt-2 text-paper-200/85">Law Society of Ontario</p>
      </div>
      <div>
        <p class="smallcaps text-[10.5px] text-gold-400">Languages</p>
        <p class="mt-2 text-paper-200/85">English · Mandarin · Punjabi · Hindi · Cantonese</p>
      </div>
    </div>
  </div>

  <!-- Bottom gold rule — serves as page-wide signature -->
  <div
    class="relative h-[2px]"
    style="background: linear-gradient(90deg, transparent 0%, var(--color-gold-600) 12%, var(--color-gold-400) 50%, var(--color-gold-500) 88%, transparent 100%);"
    aria-hidden="true"
  ></div>
</section>
